{
  "name": "stingfit",
  "private": true,
  "version": "2.0.0",
  "description": "Private, local-first fitness training logbook and plan builder.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vypa1nik/stingfit.git"
  },
  "bugs": {
    "url": "https://github.com/Vypa1nik/stingfit/issues"
  },
  "homepage": "https://github.com/Vypa1nik/stingfit",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "mobile:pwa:start": "powershell -ExecutionPolicy Bypass -File ./tools/start-mobile-pwa-preview.ps1",
    "mobile:pwa:stop": "powershell -ExecutionPolicy Bypass -File ./tools/stop-mobile-pwa-preview.ps1",
    "mobile:pwa:url": "powershell -ExecutionPolicy Bypass -Command \"if (Test-Path ./.tmp-stingfit-mobile-preview-url.txt) { Get-Content ./.tmp-stingfit-mobile-preview-url.txt } else { Write-Error 'Mobile PWA preview URL not found. Run npm run mobile:pwa:start first.' }\"",
    "qr:preview": "node ./tools/generate-preview-qr.mjs",
    "public:start": "powershell -ExecutionPolicy Bypass -File ./tools/start-public-preview.ps1",
    "public:stop": "powershell -ExecutionPolicy Bypass -File ./tools/stop-public-preview.ps1",
    "public:url": "powershell -ExecutionPolicy Bypass -Command \"if (Test-Path ./.tmp-stingfit-public-url.txt) { Get-Content ./.tmp-stingfit-public-url.txt } else { Write-Error 'Public URL not found. Run npm run public:start first.' }\"",
    "test": "vitest",
    "test:run": "vitest run",
    "check": "npm run lint && npm run test:run && npm run build",
    "agent:health": "powershell -ExecutionPolicy Bypass -File ..\\tools\\Test-AgentWorkspace.ps1 -Project localflow",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.96.2",
    "@tauri-apps/api": "^2.10.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "idb-keyval": "^6.2.2",
    "lucide-react": "1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "sql.js": "^1.14.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "qrcode": "^1.5.4",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  }
}
